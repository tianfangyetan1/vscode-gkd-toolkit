{
  "name": "gkd-toolkit",
  "displayName": "GKD Toolkit",
  "description": "GKD Toolkit for VS Code",
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:typescript"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "gkd-toolkit.openAllSnapshotUrls",
        "title": "全部打开"
      },
      {
        "command": "gkd-toolkit.openAllSnapshotUrlsWithQuery",
        "title": "全部打开并查询"
      },
      {
        "command": "gkd-toolkit.collapseAllRules",
        "title": "折叠所有规则"
      }
    ],
    "configuration": {
      "title": "GKD Toolkit",
      "properties": {
        "gkd-toolkit.outline.hideSingleRule": {
          "type": "boolean",
          "default": true,
          "description": "当规则组内只有一条规则时，不在大纲中单独显示规则"
        },
        "gkd-toolkit.collapseAllRules.show": {
          "type": "boolean",
          "default": false,
          "description": "实验性：在规则文件顶部显示「折叠所有规则」按钮，下次打开时自动展开折叠的部分"
        }
      }
    }
  },
  "publisher": "tianfangyetan",
  "author": {
    "name": "tianfangyetan1"
  },
  "icon": "resources/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/tianfangyetan1/vscode-gkd-toolkit.git"
  },
  "scripts": {
    "build": "vsce package",
    "vscode:prepublish": "pnpm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.109.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "ts-loader": "^9.5.4",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}